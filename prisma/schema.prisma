generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MatchStatus {
  MATCHED
  PENDING
  UNMATCHED
}

model Document {
  id            String         @id @default(cuid())
  type          String
  docNumber     String?
  baNumber      String?        // New field for Berita Acara
  baDate        DateTime?      // New field for Berita Acara date
  kodeRek       String?
  subKegiatan   String?
  vendorName    String?
  totalAmount   Float?
  date          DateTime?
  imageUrl      String?
  extractedText String?
  paymentFor    String?        // New field for BKU matching
  unit          String?        // Global unit if applicable
  division      String?        // New field for Bidang
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  items         DocumentItem[]
  matchRecord   MatchRecord?

  @@index([docNumber])
  @@index([vendorName])
  @@index([date])
}

model DocumentItem {
  id          String   @id @default(cuid())
  documentId  String
  description String
  itemCode    String?  // New field for Item Code
  quantity    Float?
  price       Float?
  unit        String?  // New field for Satuan (e.g., buah, ltr)
  total       Float?
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model BkuTransaction {
  id           String       @id @default(cuid())
  date         String?
  month        Int
  year         Int
  code         String?
  description  String
  receiptTotal Float?
  expenseTotal Float?
  balance      Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  matchRecord  MatchRecord?

  @@index([month, year])
  @@index([date])
}

model MatchRecord {
  id               String         @id @default(cuid())
  bkuTransactionId String         @unique
  documentId       String         @unique
  confidence       Float
  status           MatchStatus    @default(PENDING)
  reasoning        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  bkuTransaction   BkuTransaction @relation(fields: [bkuTransactionId], references: [id], onDelete: Cascade)
  document         Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model MasterItem {
  id          String   @id @default(cuid())
  code        String   @unique
  description String
  unit        String?
  price       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
}

model AccountCodeMapping {
  id        String   @id @default(cuid())
  year      Int      @default(2026) // Multi-year support
  subKegiatan String?
  code      String   
  name      String
  division  String?        // New field for Bidang
  budget    Float?         @default(0) // Pagu Murni / Awal
  revisedBudget Float?    @default(0) // Pagu Perubahan
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  budgetLogs BudgetLog[]

  @@unique([code, year])
  @@index([code])
  @@index([year])
}

model BudgetLog {
  id        String   @id @default(cuid())
  mappingId String
  field     String   @default("budget") // "budget" or "revisedBudget"
  oldBudget Float
  newBudget Float
  reason    String?
  createdAt DateTime @default(now())
  mapping   AccountCodeMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  @@index([mappingId])
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
