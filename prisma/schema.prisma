generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MatchStatus {
  MATCHED
  PENDING
  UNMATCHED
}

model Document {
  id            String         @id @default(cuid())
  type          String
  docNumber     String?
  baNumber      String?        // New field for Berita Acara
  baDate        DateTime?      // New field for Berita Acara date
  kodeRek       String?
  subKegiatan   String?
  vendorName    String?
  totalAmount   Float?
  date          DateTime?
  imageUrl      String?
  extractedText String?
  paymentDescription String? // New field for BKU matching
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  items         DocumentItem[]
  matchRecord   MatchRecord?

  @@index([docNumber])
  @@index([vendorName])
  @@index([date])
}

model DocumentItem {
  id          String   @id @default(cuid())
  documentId  String
  description String
  itemCode    String?  // New field for Item Code
  quantity    Float?
  price       Float?
  total       Float?
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model BkuTransaction {
  id           String       @id @default(cuid())
  date         String?
  month        Int
  year         Int
  code         String?
  description  String
  receiptTotal Float?
  expenseTotal Float?
  balance      Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  matchRecord  MatchRecord?

  @@index([month, year])
  @@index([date])
}

model MatchRecord {
  id               String         @id @default(cuid())
  bkuTransactionId String         @unique
  documentId       String         @unique
  confidence       Float
  status           MatchStatus    @default(PENDING)
  reasoning        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  bkuTransaction   BkuTransaction @relation(fields: [bkuTransactionId], references: [id], onDelete: Cascade)
  document         Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
}
