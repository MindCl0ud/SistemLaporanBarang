generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AssetType {
  KENDARAAN_DINAS
  PERALATAN_KOMPUTER
  PERLENGKAPAN_KOMPUTER
  LAINNYA
}

enum AssetStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
  DAMAGED
}

enum BookingStatus {
  PENDING
  APPROVED
  ONGOING
  COMPLETED
  CANCELLED
}

enum LogType {
  PICKUP
  RETURN
}

model User {
  id        String    @id @default(cuid())
  name      String
  nip       String?   @unique
  role      String    @default("USER")
  bookings  Booking[]
}

model Asset {
  id           String      @id @default(cuid())
  name         String
  description  String?
  type         AssetType
  sipdId       String?     @unique
  status       AssetStatus @default(AVAILABLE)
  brand        String?
  model        String?
  licensePlate String?
  serialNumber String?
  imageUrl     String?
  bookings     Booking[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Booking {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  assetId      String
  asset        Asset         @relation(fields: [assetId], references: [id])
  startDate    DateTime
  endDate      DateTime
  purpose      String
  status       BookingStatus @default(PENDING)
  notes        String?
  logs         HandoverLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model HandoverLog {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  type         LogType
  condition    String   // Description of condition (e.g., "Good", "Scratched")
  timestamp    DateTime @default(now())
  responsible  String   // Person handling the handover
}
